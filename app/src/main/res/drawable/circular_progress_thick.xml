<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:thicknessRatio="5.5" android:useLevel="false">
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thicknessRatio="5.5" android:useLevel="true">
                <gradient
                    android:angle="0"
                    android:endColor="#4263EB"
                    android:startColor="#7B9BFF"
                    android:type="sweep" />
            </shape>
        </rotate>
    </item>
</layer-list>