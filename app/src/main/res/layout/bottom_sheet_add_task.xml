<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#1A2244" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Create New Flow"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"/>

    <!-- Title Input — unchanged -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp"
        app:boxStrokeColor="#4263EB"
        app:hintTextColor="?android:attr/textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What do you want to focus on?"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="textCapSentences"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ══════════════════════════════════════════════════ -->
    <!--   AI CATEGORY CHIP                                 -->
    <!--   Appears automatically as user types.             -->
    <!--   Tap to open category picker.                     -->
    <!--   Controlled by AddTaskBottomSheet.java            -->
    <!-- ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutCategoryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1A2244"
            app:cardBackgroundColor="#0D1A33">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp">

                <TextView
                    android:id="@+id/tvCategoryEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvCategoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="General"
                    android:textColor="#445588"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="▾"
                    android:textColor="#334466"
                    android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="auto-detected  ·  tap to change"
            android:textColor="#223355"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- Description Input — unchanged -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp"
        app:boxStrokeColor="#4263EB"
        app:hintTextColor="?android:attr/textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes / Links (Optional)"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:gravity="top"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Duration Input — unchanged -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp"
        app:boxStrokeColor="#4263EB"
        app:hintTextColor="?android:attr/textColorSecondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duration (in minutes, e.g. 30)"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="number"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ══════════════════════════════════════════════════ -->
    <!--   AI DURATION SUGGESTION                           -->
    <!--   Appears below duration field when predicted.     -->
    <!--   Tap to auto-fill duration.                       -->
    <!--   Hides if user types their own duration.          -->
    <!-- ══════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDurationSuggestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#0D3A1A"
        app:cardBackgroundColor="#061A10">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tvDurationSuggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱  ~45 min  ·  based on your history"
                android:textColor="#20C997"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Tap to use"
                android:textColor="#0D5C3A"
                android:textSize="10sp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Type selector — exact original IDs kept, unchanged -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTypeRoutine"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Daily Routine"
            android:textSize="13sp"
            app:cornerRadius="16dp"
            app:strokeColor="#4263EB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTypeTask"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="One-Time Task"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            app:cornerRadius="16dp"
            app:strokeColor="?android:attr/textColorTertiary" />
    </LinearLayout>

    <!-- Time Picker — unchanged -->
    <LinearLayout
        android:id="@+id/btnPickTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/rounded_input_bg"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_timer"
            app:tint="#4263EB" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Time"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00 AM"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Date Picker — unchanged -->
    <LinearLayout
        android:id="@+id/btnPickDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/rounded_input_bg"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_calendar"
            app:tint="#4263EB" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Date"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Repeat Picker — unchanged -->
    <LinearLayout
        android:id="@+id/btnPickRepeat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:background="@drawable/rounded_input_bg"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_calendar"
            app:tint="#4263EB" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Repeat"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSelectedRepeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="None"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Save Button — unchanged -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Save to Planner"
        android:textSize="15sp"
        android:letterSpacing="0.04"
        android:textStyle="bold"
        app:backgroundTint="#4263EB"
        app:cornerRadius="20dp"
        app:rippleColor="#40FFFFFF"/>

    <!-- Cancel Button — unchanged -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="6dp"
        android:text="Cancel"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"/>

</LinearLayout>