<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080818"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- ══════════════════════════════════════════ -->
        <!--              PAGE HEADER                   -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#EEEEFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Customize your FocusFlow"
                android:textColor="#334466"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!--            PROFILE HERO CARD               -->
        <!-- ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/progress_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="28dp"
                android:paddingHorizontal="24dp">

                <!-- Decorative orb -->
                <View
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="-80dp"
                    android:layout_marginEnd="-60dp"
                    android:alpha="0.07"
                    android:background="@drawable/alarm_icon_bg"/>

                <!-- Avatar ring -->
                <RelativeLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/alarm_icon_bg"
                        android:alpha="0.25"
                        android:layout_centerInParent="true"/>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_centerInParent="true"
                        android:background="#0D1540"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImageView"/>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnEditProfile"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="#4263EB"
                        app:cardBackgroundColor="#0D1540">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="7dp"
                            android:src="@drawable/ic_edit"
                            app:tint="#FFFFFF"/>
                    </com.google.android.material.card.MaterialCardView>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Focus Champion"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap name to edit"
                    android:textColor="#AABBFF"
                    android:textSize="12sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════ -->
        <!--        LEVEL / XP CARD (below profile)     -->
        <!-- ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0E0E24"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A2244"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Top row: badge + title + level + XP numbers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvSettingsXPBadge"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="🌱"
                        android:textSize="20sp"
                        android:background="@drawable/alarm_icon_bg"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSettingsXPTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Novice"
                            android:textColor="#EEEEFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvSettingsXPLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Level 1"
                            android:textColor="#4263EB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSettingsXPNumbers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 100 XP"
                        android:textColor="#334466"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- XP bar track -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#0D1A33">

                    <View
                        android:id="@+id/viewSettingsXPFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/tab_selected_bg"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Streak + total XP row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvSettingsStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 0 day streak"
                        android:textColor="#F59F00"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvSettingsTotalXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP total"
                        android:textColor="#1A2244"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Next level label -->
                <TextView
                    android:id="@+id/tvSettingsNextLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Next: Apprentice 📖"
                    android:textColor="#334466"
                    android:textSize="11sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════ -->
        <!--          SECTION: SMART FEATURES           -->
        <!-- ══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="10dp"
            android:text="SMART FEATURES"
            android:textColor="#334466"
            android:textSize="11sp"
            android:letterSpacing="0.14"
            android:textStyle="bold"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0E0E24"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A2244"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/switchAutoRollover"
                    android:layout_marginEnd="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↩  Auto-Rollover Tasks"
                        android:textColor="#EEEEFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Move yesterday's pending tasks to today"
                        android:textColor="#334466"
                        android:textSize="12sp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAutoRollover"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════ -->
        <!--      SECTION: ALARM & NOTIFICATIONS        -->
        <!-- ══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="10dp"
            android:text="ALARM &amp; NOTIFICATIONS"
            android:textColor="#334466"
            android:textSize="11sp"
            android:letterSpacing="0.14"
            android:textStyle="bold"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0E0E24"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A2244"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Push Notifications -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔔  Push Notifications"
                            android:textColor="#EEEEFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Task reminders and alerts"
                            android:textColor="#334466"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0D1A33" android:layout_marginHorizontal="20dp"/>

                <!-- Full Screen Alarm -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰  Full-Screen Alarm"
                            android:textColor="#EEEEFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Show alarm screen over other apps"
                            android:textColor="#334466"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAlarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0D1A33" android:layout_marginHorizontal="20dp"/>

                <!-- Vibrate -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📳  Vibrate on Alert"
                            android:textColor="#EEEEFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Haptic feedback when alarm triggers"
                            android:textColor="#334466"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchVibrate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0D1A33" android:layout_marginHorizontal="20dp"/>

                <!-- Ringtone -->
                <RelativeLayout
                    android:id="@+id/btnRingtonePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵  Alarm Ringtone"
                            android:textColor="#EEEEFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Choose your alarm sound"
                            android:textColor="#334466"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRingtoneName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Default ›"
                        android:textColor="#4263EB"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </RelativeLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════ -->
        <!--              DANGER ZONE                   -->
        <!-- ══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="10dp"
            android:text="DANGER ZONE"
            android:textColor="#6B1515"
            android:textSize="11sp"
            android:letterSpacing="0.14"
            android:textStyle="bold"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="#120808"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A1010"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️  Clear All Data"
                        android:textColor="#EF4444"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Permanently delete all routines &amp; tasks"
                        android:textColor="#6B1515"
                        android:textSize="12sp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearData"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="Reset"
                    android:textColor="#EF4444"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:strokeColor="#44EF4444"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:text="FocusFlow • Built with ❤️"
            android:textColor="#1A2244"
            android:textSize="12sp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>