<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A"
    android:fillViewport="true"
    android:paddingTop="88dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A254D"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/greeting_card_bg"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="-40dp"
                        android:layout_marginEnd="-40dp"
                        android:alpha="0.05"
                        android:background="@drawable/alarm_icon_bg"/>

                    <LinearLayout
                        android:id="@+id/layoutGreeting"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/layoutProgressRight"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/circle_bg_light"
                                android:backgroundTint="#FFD43B"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/tvGreetingTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GOOD\nMORNING"
                                android:textColor="#8899CC"
                                android:textSize="11sp"
                                android:letterSpacing="0.15"
                                android:lineSpacingExtra="2dp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvGreetingName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Focus Master"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.03"
                            android:fontFamily="sans-serif-black"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:id="@+id/tvDailyQuote"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text='"Progress over perfection."'
                            android:textColor="#556688"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="2"
                            android:lineSpacingMultiplier="1.2"/>

                        <TextView
                            android:id="@+id/tvMotivation"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:text=""
                            android:visibility="invisible"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgressRight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <FrameLayout
                            android:id="@+id/progressContainer"
                            android:layout_width="85dp"
                            android:layout_height="85dp">

                            <ProgressBar
                                android:id="@+id/progressBarBg"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:progressDrawable="@drawable/circular_progress_bg"/>

                            <ProgressBar
                                android:id="@+id/progressBar"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:max="100"
                                android:progress="0"
                                android:progressDrawable="@drawable/circular_progress"/>

                            <TextView
                                android:id="@+id/tvProgressPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="0%"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black"/>

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvProgressSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0 of 0 done"
                            android:textColor="#7788AA"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </RelativeLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardXP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="42dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#111B3D"
                                app:strokeWidth="1.5dp"
                                app:strokeColor="#3A4D99"
                                android:layout_marginEnd="12dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp">

                                    <TextView
                                        android:id="@+id/tvXPBadge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="LVL"
                                        android:textColor="#88AADD"
                                        android:textSize="8sp"
                                        android:textStyle="bold"
                                        android:letterSpacing="0.15"/>

                                    <TextView
                                        android:id="@+id/tvXPLevelLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1"
                                        android:textColor="#FFFFFF"
                                        android:textSize="16sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/tvXPTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Novice"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:letterSpacing="-0.01"/>

                                    <TextView
                                        android:id="@+id/tvStreakValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="🔥"
                                        android:textColor="#FF6B6B"
                                        android:textSize="14sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layoutNextTaskTimer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/rounded_input_bg"
                                android:backgroundTint="#1AFA5252"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_bg_light"
                                    android:backgroundTint="#FA5252"/>

                                <TextView
                                    android:id="@+id/tvNextTaskTimer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Next: –"
                                    android:textColor="#FF8888"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView android:id="@+id/tvTotalXP" android:layout_width="0dp" android:layout_height="0dp" android:visibility="invisible"/>
                        <TextView android:id="@+id/tvXPNumbers" android:layout_width="0dp" android:layout_height="0dp" android:visibility="invisible"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/cardProgress" android:layout_width="0dp" android:layout_height="0dp" android:visibility="invisible" app:cardBackgroundColor="@android:color/transparent" app:cardElevation="0dp" app:strokeWidth="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:id="@+id/cvProfilePhoto" android:layout_width="0dp" android:layout_height="0dp" android:visibility="invisible" app:cardElevation="0dp" app:strokeWidth="0dp">
                            <ImageView android:id="@+id/ivProfilePhoto" android:layout_width="match_parent" android:layout_height="match_parent"/>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            app:cardCornerRadius="3dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="#0D152D">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <View
                                    android:id="@+id/viewXPFill"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/tab_selected_bg"/>

                                <View
                                    android:id="@+id/viewXPShimmer"
                                    android:layout_width="60dp"
                                    android:layout_height="match_parent"
                                    android:background="#44FFFFFF"
                                    android:translationX="-60dp"
                                    android:visibility="invisible"/>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="420 XP"
                                android:textColor="#667799"
                                android:textSize="10sp"
                                android:textStyle="bold"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="600 next level"
                                android:textColor="#4263EB"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#151A30"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#080814">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#4263EB"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Search tasks, routines, locations..."
                    android:textSize="14sp"
                    android:textColor="#EEEEFF"
                    android:textColorHint="#445577"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:paddingVertical="14dp"
                    android:importantForAutofill="no"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#1A1A33">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#556688"
                        android:padding="6dp"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRolloverBanner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <TextView android:id="@+id/tvRolloverTitle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvRolloverSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <ImageView android:id="@+id/ivDismissRollover" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#121225"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#060612">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp">

                <TextView
                    android:id="@+id/tvTabRoutines"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ROUTINES"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:background="@drawable/tab_selected_bg"/>

                <TextView
                    android:id="@+id/tvTabTasks"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TASKS"
                    android:textColor="#556688"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:id="@+id/tvTabPending"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="PENDING"
                    android:textColor="#556688"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:id="@+id/tvTabGeo"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="📍 GEO"
                    android:textColor="#556688"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAIPriority"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D0D22"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3A7E"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvAIPriorityLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🧠 AI Priority"
                    android:textColor="#8899CC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"/>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddGeofence"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:visibility="gone"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D2A1A"
                app:strokeWidth="1dp"
                app:strokeColor="#1A5A3A"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvAddGeofenceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📍 Add Location"
                    android:textColor="#20C997"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <View android:id="@+id/lineTabRoutines" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/lineTabTasks" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/lineTabPending" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="40dp"/> <nl.dionsegijn.konfetti.xml.KonfettiView
            android:id="@+id/konfettiView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        </FrameLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>