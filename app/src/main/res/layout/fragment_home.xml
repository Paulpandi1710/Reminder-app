<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080818"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="110dp">

        <!-- ══════════════════════════════════════════════ -->
        <!--     GREETING CARD — GLASSMORPHISM + GLOW       -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/greeting_card_bg"
                android:padding="22dp">

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="-30dp"
                    android:layout_marginEnd="-30dp"
                    android:alpha="0.2"
                    android:background="@drawable/alarm_icon_bg"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true"
                    android:layout_marginBottom="-20dp"
                    android:layout_marginStart="-10dp"
                    android:alpha="0.1"
                    android:background="@drawable/alarm_icon_bg"/>

                <LinearLayout
                    android:id="@+id/layoutGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@+id/cvProfilePhoto"
                    android:layout_marginEnd="16dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreetingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning ☀️"
                        android:textColor="#7B9BFF"
                        android:textSize="12sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvGreetingName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Focus Master"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"
                        android:fontFamily="sans-serif-black"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/tab_selected_bg"/>

                    <TextView
                        android:id="@+id/tvDailyQuote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='"Getting started is the secret."'
                        android:textColor="#5566AA"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="2"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvProfilePhoto"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="12dp"
                    app:strokeColor="#4263EB"
                    app:strokeWidth="2dp">

                    <ImageView
                        android:id="@+id/ivProfilePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_foreground"
                        android:background="#0D1117"/>
                </com.google.android.material.card.MaterialCardView>

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--         XP LEVEL CARD                          -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardXP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#0E0E24"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A2244"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvXPBadge"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="🌱"
                        android:textSize="20sp"
                        android:background="@drawable/alarm_icon_bg"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvXPTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Novice"
                            android:textColor="#EEEEFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01"/>

                        <TextView
                            android:id="@+id/tvXPLevelLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Level 1"
                            android:textColor="#4263EB"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvXPNumbers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 100 XP"
                        android:textColor="#334466"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#0D1A33">

                    <View
                        android:id="@+id/viewXPFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/tab_selected_bg"/>

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tvStreakValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 0 day streak"
                        android:textColor="#F59F00"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvTotalXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP total"
                        android:textColor="#1A2244"
                        android:textSize="11sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--            AUTO-ROLLOVER BANNER                -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRolloverBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#334263EB"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#0A1232">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="↩"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/alarm_icon_bg"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRolloverTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks Rolled Over"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvRolloverSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Yesterday's pending tasks moved to today"
                        android:textColor="#5566AA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivDismissRollover"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="4dp"
                    app:tint="#5566AA"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--              SEARCH BAR                        -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#141430"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#0E0E24">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#334466"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="Search your flows..."
                    android:textSize="14sp"
                    android:textColor="#CCCCDD"
                    android:textColorHint="#334466"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:paddingVertical="16dp"/>

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#334466"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--         DAILY PROGRESS CARD                    -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/progress_card_bg"
                android:padding="24dp">

                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginEnd="-50dp"
                    android:layout_marginBottom="-50dp"
                    android:alpha="0.1"
                    android:background="@drawable/alarm_icon_bg"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/progressContainer"
                    android:layout_marginEnd="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DAILY PROGRESS"
                        android:textColor="#99BBFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvMotivation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Ready to Flow?"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:id="@+id/tvProgressSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 of 0 objectives completed"
                        android:textColor="#99BBFF"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3"/>

                    <LinearLayout
                        android:id="@+id/layoutNextTaskTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/rounded_input_bg"
                        android:backgroundTint="#22FFFFFF"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="9dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_timer"
                            app:tint="#FFFFFF"/>

                        <TextView
                            android:id="@+id/tvNextTaskTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Next: No upcoming tasks"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/progressContainer"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <ProgressBar
                        android:id="@+id/progressBarBg"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/circular_progress_bg"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/circular_progress"/>

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="0%"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </RelativeLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--      4-TAB PILL SWITCHER (+ GEO tab)           -->
        <!-- ══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#0F0F28"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#0C0C20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp">

                <TextView
                    android:id="@+id/tvTabRoutines"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ROUTINES"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:background="@drawable/tab_selected_bg"/>

                <TextView
                    android:id="@+id/tvTabTasks"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:gravity="center"
                    android:text="TASKS"
                    android:textColor="#334466"
                    android:textSize="9sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:id="@+id/tvTabPending"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="PENDING"
                    android:textColor="#334466"
                    android:textSize="9sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

                <!-- NEW: GEO tab -->
                <TextView
                    android:id="@+id/tvTabGeo"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="📍 GEO"
                    android:textColor="#334466"
                    android:textSize="9sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════════════ -->
        <!--   AI PRIORITY SORT BUTTON + GEO ADD BUTTON     -->
        <!-- ══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <!-- AI Priority sort toggle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAIPriority"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D0D22"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3A7E"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvAIPriorityLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🧠 AI Priority"
                    android:textColor="#8899CC"
                    android:textSize="11sp"
                    android:paddingHorizontal="14dp"/>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Add Geofence button — shown only in GEO tab -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddGeofence"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D2A1A"
                app:strokeWidth="1dp"
                app:strokeColor="#1A5A3A"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvAddGeofenceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📍 Add Location"
                    android:textColor="#20C997"
                    android:textSize="11sp"
                    android:paddingHorizontal="14dp"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Hidden line views — kept for Java compatibility -->
        <View android:id="@+id/lineTabRoutines" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/lineTabTasks" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/lineTabPending" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone"/>

        <!-- ══════════════════════════════════════════════ -->
        <!--       TASK RECYCLER + KONFETTI OVERLAY         -->
        <!-- ══════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:paddingTop="4dp"/>

            <nl.dionsegijn.konfetti.xml.KonfettiView
                android:id="@+id/konfettiView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>