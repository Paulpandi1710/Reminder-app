<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#05050A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A2244">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#334263EB"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Location Reminder"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search address or tap map to place pin"
                    android:textColor="#8899BB"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#334263EB"
            app:cardBackgroundColor="#0AFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etAddressSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search address or place name..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#556688"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSearch"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A4263EB">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🔍"
                        android:textSize="16sp"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearchResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#334263EB"
            app:cardBackgroundColor="#0A0A1A">

            <LinearLayout
                android:id="@+id/layoutSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp"/>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#334263EB"
            app:cardBackgroundColor="#05050A">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <WebView
                    android:id="@+id/webViewMap"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <LinearLayout
                    android:id="@+id/layoutMapLoading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#0A0A1A"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗺️"
                        android:textSize="36sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading map..."
                        android:textColor="#8899BB"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="48dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCoordsDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#3320C997"
                    app:cardBackgroundColor="#0A20C997">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/tvCoordsDisplay"
                            android:text="📌 No pin placed yet"
                            android:textColor="#20C997"
                            android:textStyle="bold"
                            android:textSize="12sp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardUseCurrentLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#20C997">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📡 Update Location"
                                android:textColor="#05050A"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="14dp"/>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGPSOnly"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#3320C997"
                    app:cardBackgroundColor="#0A20C997">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="📡 Use My Current Location"
                        android:textColor="#20C997"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION NAME"
                    android:textColor="#7B9BFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#1A2244"
                    app:cardBackgroundColor="#0AFFFFFF">
                    <EditText
                        android:id="@+id/etGeoTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="e.g. Office, Gym, Home"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#556688"
                        android:textSize="15sp"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="14dp"
                        android:inputType="textCapSentences"
                        android:maxLines="1"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REMINDER NOTE (optional)"
                    android:textColor="#7B9BFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#1A2244"
                    app:cardBackgroundColor="#0AFFFFFF">
                    <EditText
                        android:id="@+id/etGeoNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="e.g. Don't forget to check Slack"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#556688"
                        android:textSize="14sp"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="14dp"
                        android:inputType="textCapSentences"
                        android:maxLines="2"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRIGGER RADIUS"
                    android:textColor="#7B9BFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRad50"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp">
                        <TextView
                            android:id="@+id/tvRad50"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="50m"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRad100"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp">
                        <TextView
                            android:id="@+id/tvRad100"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="100m"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRad200"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp">
                        <TextView
                            android:id="@+id/tvRad200"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="200m"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRad500"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp">
                        <TextView
                            android:id="@+id/tvRad500"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="500m"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSaveGeofence"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#4263EB">

                    <TextView
                        android:id="@+id/tvSaveLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="📍 Save Location Reminder"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:letterSpacing="0.04"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>