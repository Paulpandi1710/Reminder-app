<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080818"
    android:orientation="vertical"
    android:descendantFocusability="afterDescendants">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAIHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good evening 👋"
                android:textColor="#EEEEFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvAISubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="AI-powered · personalised to your schedule"
                android:textColor="#334466"
                android:textSize="11sp"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1A2244"
            app:cardBackgroundColor="#0A0A1E">

            <TextView
                android:id="@+id/tvOnlineStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Offline"
                android:textColor="#556688"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- QUICK CHIPS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutQuickActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D0D22"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="4dp"/>

    <!-- CHAT -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:scrollbars="none"/>

    <!-- TYPING INDICATOR -->
    <LinearLayout
        android:id="@+id/layoutTypingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1A2244"
            app:cardBackgroundColor="#0E0E24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ···  thinking  "
                android:textColor="#4263EB"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- SUGGESTION CHIPS -->
    <HorizontalScrollView
        android:id="@+id/scrollSuggestionChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutSuggestionChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- INPUT BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_input_bg"
        android:backgroundTint="#0E0E24"
        android:paddingStart="18dp"
        android:paddingEnd="8dp"
        android:paddingVertical="4dp"
        android:clickable="false">

        <EditText
            android:id="@+id/etAIInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Message… or tap 🎤 to speak"
            android:textSize="15sp"
            android:textColor="#DDDDEE"
            android:textColorHint="#445577"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend|flagNoExtractUi"
            android:maxLines="5"
            android:minLines="1"
            android:paddingVertical="14dp"
            android:paddingEnd="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:cursorVisible="true"
            android:importantForAutofill="no"/>

        <!-- MIC BUTTON — left of send, pulsing red when listening -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMicBtn"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A3A"
            app:strokeWidth="1dp"
            app:strokeColor="#2A3A7E"
            android:clickable="false"
            android:focusable="false">

            <ImageView
                android:id="@+id/btnMicAI"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_mic"
                android:padding="13dp"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                app:tint="#445577"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- SEND BUTTON -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSendBtn"
            android:layout_width="46dp"
            android:layout_height="46dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1A1A3A"
            app:strokeWidth="1dp"
            app:strokeColor="#2A3A7E"
            android:clickable="false"
            android:focusable="false">

            <ImageView
                android:id="@+id/btnSendAI"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_send"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                app:tint="#445577"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>