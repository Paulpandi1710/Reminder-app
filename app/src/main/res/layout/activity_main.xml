<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout="@layout/fragment_home"/>

    <LinearLayout
        android:id="@+id/layoutTopRightIcons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBellIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0AFFFFFF"
                app:strokeWidth="1.5dp"
                app:strokeColor="#2A4263EB">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🔔"
                    android:textSize="18sp"/>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvNotifBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/alarm_icon_bg"
                android:backgroundTint="#EF4444"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:elevation="2dp"/>
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSettingsIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0AFFFFFF"
            app:strokeWidth="1.5dp"
            app:strokeColor="#2A4263EB">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_settings"
                app:tint="#7B9BFF"/>

        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:clipChildren="false">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="#0AFFFFFF"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A4263EB"
            app:strokeWidth="1.5dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNavigationView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                app:itemIconTint="@drawable/selector_nav_icon"
                app:itemTextColor="@drawable/selector_nav_icon"
                app:itemIconSize="24dp"
                app:labelVisibilityMode="unlabeled"
                app:menu="@menu/bottom_nav_menu"
                app:elevation="0dp" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="18dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/fabAura"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_bg_light"
                android:backgroundTint="#4263EB" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_add"
                android:contentDescription="Add Task"
                app:tint="#FFFFFF"
                app:backgroundTint="#4263EB"
                app:elevation="8dp"
                app:fabCustomSize="58dp"
                app:maxImageSize="28dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialComponents.FloatingActionButton" />
        </FrameLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>