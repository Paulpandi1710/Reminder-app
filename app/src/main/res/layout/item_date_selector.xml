<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="58dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Day of week label — always visible -->
    <TextView
        android:id="@+id/tvDayOfWeek"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="MON"
        android:textColor="#8899CC"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"/>

    <!-- Date circle -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDateCircle"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:cardCornerRadius="21dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#0E0E24">

        <TextView
            android:id="@+id/tvDayNumber"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="1"
            android:textColor="#AABBDD"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Dot indicator for items on this day -->
    <View
        android:id="@+id/viewDot"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/alarm_icon_bg"
        android:visibility="invisible"/>

</LinearLayout>