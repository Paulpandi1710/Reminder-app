<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE04040A">

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/levelUpKonfetti"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="32dp"
        app:cardBackgroundColor="#0AFFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeColor="#334263EB"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="48dp"
            android:paddingBottom="36dp">

            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp">

                <View
                    android:id="@+id/levelUpAura"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_bg_light"
                    android:backgroundTint="#4263EB"
                    android:alpha="0.2"/>

                <TextView
                    android:id="@+id/tvLevelUpBadge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🏆"
                    android:textSize="64sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL UP!"
                android:textColor="#7B9BFF"
                android:textSize="14sp"
                android:letterSpacing="0.20"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvLevelUpLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL 5"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLevelUpTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disciplined"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLevelUpSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You've reached a new rank!"
                android:textColor="#8899BB"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="28dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#1A4263EB">

                <TextView
                    android:id="@+id/tvLevelUpXPEarned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+25 XP"
                    android:textColor="#AACCFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"/>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLevelUpDismiss"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="LET'S GO! 🚀"
                android:textSize="15sp"
                android:letterSpacing="0.06"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#4263EB"
                app:cornerRadius="28dp"
                app:rippleColor="#40FFFFFF"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>