<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE080818">

    <!-- Konfetti lives behind everything -->
    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/levelUpKonfetti"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Center card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="32dp"
        app:cardBackgroundColor="#0E0E24"
        app:cardCornerRadius="32dp"
        app:cardElevation="24dp"
        app:strokeColor="#334263EB"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <!-- Glow ring behind badge -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/alarm_icon_bg"
                    android:alpha="0.2"/>

                <TextView
                    android:id="@+id/tvLevelUpBadge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🏆"
                    android:textSize="52sp"/>
            </FrameLayout>

            <!-- LEVEL UP label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL UP!"
                android:textColor="#4263EB"
                android:textSize="12sp"
                android:letterSpacing="0.20"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Level number -->
            <TextView
                android:id="@+id/tvLevelUpLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL 5"
                android:textColor="#EEEEFF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="4dp"/>

            <!-- New title -->
            <TextView
                android:id="@+id/tvLevelUpTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disciplined"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvLevelUpSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You've reached a new rank!"
                android:textColor="#5566AA"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- XP earned pill -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#154263EB">

                <TextView
                    android:id="@+id/tvLevelUpXPEarned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+25 XP"
                    android:textColor="#4263EB"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="10dp"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Dismiss button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLevelUpDismiss"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="LET'S GO! 🚀"
                android:textSize="14sp"
                android:letterSpacing="0.06"
                android:textStyle="bold"
                app:backgroundTint="#4263EB"
                app:cornerRadius="18dp"
                app:rippleColor="#40FFFFFF"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>