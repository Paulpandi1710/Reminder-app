<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A"
    android:keepScreenOn="true">

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-150dp"
        android:background="@drawable/circle_bg_light"
        android:backgroundTint="#154263EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginBottom="200dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <RelativeLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.3"
                android:background="@drawable/circle_bg_light"
                android:backgroundTint="#4263EB"
                android:layout_centerInParent="true"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_centerInParent="true"
                app:cardCornerRadius="48dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#334263EB"
                app:cardBackgroundColor="#0AFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_timer"
                        app:tint="#FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIME TO FOCUS"
            android:textColor="#7B9BFF"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvAlarmTaskTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Task"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:lineSpacingMultiplier="1.2"
            android:paddingHorizontal="16dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="48dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReady"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:text="MARK DONE &amp; START"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.06"
            android:textStyle="bold"
            app:backgroundTint="#20C997"
            app:cornerRadius="20dp"
            app:rippleColor="#40FFFFFF"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnooze"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="16dp"
            android:text="⏰  SNOOZE 10 MINS"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.04"
            android:textStyle="bold"
            app:backgroundTint="#4263EB"
            app:cornerRadius="20dp"
            app:rippleColor="#40FFFFFF"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPending"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="PENDING"
                android:textColor="#F59F00"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:strokeColor="#44F59F00"
                app:rippleColor="#20F59F00"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDismiss"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="DISMISS"
                android:textColor="#FA5252"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:strokeColor="#44FA5252"
                app:rippleColor="#20FA5252"/>

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>